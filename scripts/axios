#!/usr/bin/env bash
set -e

SOCKET_DIR="${AXIOS_SOCKET_DIR:-/tmp/axios-mcp}"
PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PIDS=()

cleanup() {
  echo ""
  echo "Shutting down AxiOS..."
  for pid in "${PIDS[@]}"; do
    kill "$pid" 2>/dev/null || true
  done
  rm -f "$SOCKET_DIR"/*.sock
  wait 2>/dev/null
  echo "AxiOS stopped."
}

trap cleanup EXIT INT TERM

cd "$PROJECT_DIR"

case "${1:-start}" in
  start)
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  AxiOS — Starting all services..."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Create socket directory
    mkdir -p "$SOCKET_DIR"

    # 1. MCP Servers
    echo "[1/3] Starting MCP servers..."
    go run ./cmd/axios-fs --socket "$SOCKET_DIR/axios-fs.sock" &
    PIDS+=($!)
    go run ./cmd/axios-system --socket "$SOCKET_DIR/axios-system.sock" &
    go run ./cmd/axios-docker --socket "$SOCKET_DIR/axios-docker.sock" &
    go run ./cmd/axios-ollama --socket "$SOCKET_DIR/axios-ollama.sock" &
    PIDS+=($!)
    go run ./cmd/axios-network --socket "$SOCKET_DIR/axios-network.sock" &
    PIDS+=($!)
    go run ./cmd/axios-git --socket "$SOCKET_DIR/axios-git.sock" &
    PIDS+=($!)
    go run ./cmd/axios-obsidian --socket "$SOCKET_DIR/axios-obsidian.sock" &
    PIDS+=($!)
    sleep 1

    # 2. axiosd daemon
    echo "[2/3] Starting axiosd daemon..."
    go run ./cmd/axiosd --config configs/axiosd.yaml &
    PIDS+=($!)
    sleep 1

    # 3. Web UI
    echo "[3/3] Starting web UI..."
    (cd web && npm run dev -- --host 2>&1) &
    PIDS+=($!)

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  AxiOS is running!"
    echo ""
    echo "  Web UI:  http://localhost:5173"
    echo "  API:     http://localhost:3000"
    echo ""
    echo "  Press Ctrl+C to stop all services"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    # Wait for any process to exit
    wait
    ;;

  stop)
    echo "Stopping AxiOS..."
    pkill -f "axios-fs" 2>/dev/null || true
    pkill -f "axios-system" 2>/dev/null || true
    pkill -f "axios-docker" 2>/dev/null || true
    pkill -f "axios-ollama" 2>/dev/null || true
    pkill -f "axios-network" 2>/dev/null || true
    pkill -f "axios-git" 2>/dev/null || true
    pkill -f "axios-obsidian" 2>/dev/null || true
    pkill -f "cmd/axiosd" 2>/dev/null || true
    pkill -f "vite.*axios" 2>/dev/null || true
    rm -f "$SOCKET_DIR"/*.sock
    echo "AxiOS stopped."
    ;;

  *)
    echo "Usage: axios [start|stop]"
    exit 1
    ;;
esac
