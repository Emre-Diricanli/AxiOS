#!/usr/bin/env bash
set -e

SOCKET_DIR="${AXIOS_SOCKET_DIR:-/tmp/axios-mcp}"
PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PIDS=()
PREBUILT=0

# Kill pid and all of its descendants, deepest first. Needed because
# `go run` and npm both exec their real workload as child processes that
# don't reliably die with the parent.
kill_tree() {
  local pid="$1" child
  for child in $(pgrep -P "$pid" 2>/dev/null); do
    kill_tree "$child"
  done
  kill "$pid" 2>/dev/null || true
}

cleanup() {
  trap - EXIT INT TERM  # run once
  trap '' INT TERM      # ignore the group signal we send ourselves below
  echo ""
  echo "Shutting down AxiOS..."
  # When this script leads its own process group (normal `./scripts/axios
  # start` from a terminal), one group-wide TERM reaches every service and
  # every go run/npm child. Under `make start` we are not the group leader,
  # so fall back to walking each tracked service's process tree.
  if ! kill -- "-$$" 2>/dev/null; then
    for pid in "${PIDS[@]}"; do
      kill_tree "$pid"
    done
  fi
  rm -f "$SOCKET_DIR"/*.sock
  wait 2>/dev/null || true
  echo "AxiOS stopped."
}

# Start one Go service in the background and track its PID.
run_svc() {
  local name="$1"
  shift
  if [[ "$PREBUILT" == "1" ]]; then
    "$PROJECT_DIR/bin/$name" "$@" &
  else
    go run "./cmd/$name" "$@" &
  fi
  PIDS+=($!)
}

cd "$PROJECT_DIR"

case "${1:-start}" in
  start)
    if [[ "${2:-}" == "--build" ]]; then
      PREBUILT=1
      echo "Building binaries..."
      make build
    fi

    trap cleanup EXIT INT TERM

    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  AxiOS — Starting all services..."
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Create socket directory
    mkdir -p "$SOCKET_DIR"

    # 1. MCP Servers
    echo "[1/3] Starting MCP servers..."
    run_svc axios-fs --socket "$SOCKET_DIR/axios-fs.sock"
    run_svc axios-system --socket "$SOCKET_DIR/axios-system.sock"
    run_svc axios-docker --socket "$SOCKET_DIR/axios-docker.sock"
    run_svc axios-ollama --socket "$SOCKET_DIR/axios-ollama.sock"
    run_svc axios-network --socket "$SOCKET_DIR/axios-network.sock"
    run_svc axios-git --socket "$SOCKET_DIR/axios-git.sock"
    run_svc axios-obsidian --socket "$SOCKET_DIR/axios-obsidian.sock"
    sleep 1

    # 2. axiosd daemon (connects to MCP sockets on demand, so a slow MCP
    # compile on first run self-heals via reconnect)
    echo "[2/3] Starting axiosd daemon..."
    run_svc axiosd --config configs/axiosd.yaml
    sleep 1

    # 3. Web UI
    echo "[3/3] Starting web UI..."
    (cd web && npm run dev -- --host 2>&1) &
    PIDS+=($!)

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  AxiOS is running!"
    echo ""
    echo "  Web UI:  http://localhost:5173"
    echo "  API:     http://localhost:3000"
    echo ""
    echo "  Press Ctrl+C to stop all services"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    # Wait for any process to exit
    wait
    ;;

  stop)
    echo "Stopping AxiOS..."
    # Patterns match the go run parent, its compiled child in the build
    # cache, and prebuilt bin/ binaries alike.
    pkill -f "axios-fs" 2>/dev/null || true
    pkill -f "axios-system" 2>/dev/null || true
    pkill -f "axios-docker" 2>/dev/null || true
    pkill -f "axios-ollama" 2>/dev/null || true
    pkill -f "axios-network" 2>/dev/null || true
    pkill -f "axios-git" 2>/dev/null || true
    pkill -f "axios-obsidian" 2>/dev/null || true
    pkill -f "axiosd --config" 2>/dev/null || true
    pkill -f "$PROJECT_DIR/web" 2>/dev/null || true
    rm -f "$SOCKET_DIR"/*.sock
    echo "AxiOS stopped."
    ;;

  *)
    echo "Usage: axios [start [--build]|stop]"
    exit 1
    ;;
esac
